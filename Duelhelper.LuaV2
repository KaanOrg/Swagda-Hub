local _floatC = Instance.new("Frame", _gui)
_floatC.Size = UDim2.new(0,70,0,260)
_floatC.Position = UDim2.new(1,-80,0,0.15)
_floatC.BackgroundTransparency = 1
_floatC.ZIndex = 20
local _floatLay = Instance.new("UIListLayout", _floatC)
_floatLay.Padding = UDim.new(0,8)
_floatLay.SortOrder = Enum.SortOrder.LayoutOrder

local function _mkFloat(txt1, txt2, cb, ord)
    local b = Instance.new("TextButton", _floatC)
    b.Size = UDim2.new(0,60,0,45)
    b.BackgroundColor3 = _theme.Btn
    b.Text = ""
    b.LayoutOrder = ord
    Instance.new("UICorner", b).CornerRadius = UDim.new(0,8)
    local t1 = Instance.new("TextLabel", b)
    t1.Size = UDim2.new(1,0,0,18)
    t1.Position = UDim2.new(0,0,0,4)
    t1.BackgroundTransparency = 1
    t1.Text = txt1
    t1.TextColor3 = _theme.Acc
    t1.Font = Enum.Font.GothamBold
    t1.TextSize = 11
    local t2 = Instance.new("TextLabel", b)
    t2.Size = UDim2.new(1,0,0,14)
    t2.Position = UDim2.new(0,0,0,22)
    t2.BackgroundTransparency = 1
    t2.Text = txt2
    t2.TextColor3 = Color3.fromRGB(0,0,0)
    t2.Font = Enum.Font.GothamBold
    t2.TextSize = 9
    local ind = Instance.new("Frame", b)
    ind.Size = UDim2.new(0,8,0,8)
    ind.Position = UDim2.new(0.5,-4,1,-8)
    ind.BackgroundColor3 = _theme.Off
    ind.BorderSizePixel = 0
    Instance.new("UICorner", ind).CornerRadius = UDim.new(1,0)
    local st = false
    b.MouseButton1Click:Connect(function()
        st = not st
        ind.BackgroundColor3 = st and _theme.Acc or _theme.Off
        cb(st)
    end)
    return {ind = ind}
end

local _playL = _mkFloat("PLAY", "L", function(s)
    _aL = s
    if s then
        if _aR then _aR = false _playR.ind.BackgroundColor3 = _theme.Off _stopAutoR() end
        _startAutoL()
    else
        _stopAutoL()
    end
end, 1)
local _playR = _mkFloat("PLAY", "R", function(s)
    _aR = s
    if s then
        if _aL then _aL = false _playL.ind.BackgroundColor3 = _theme.Off _stopAutoL() end
        _startAutoR()
    else
        _stopAutoR()
    end
end, 2)
local _dropFloat = _mkFloat("DROP", "BRAINROT", function(s) _drop() end, 3)
local _tpFloat = _mkFloat("TP", "DOWN", function(s) _tpDown() end, 4)
local _batFloat = _mkFloat("BAT", "AIMBOT", function(s)
    _en.BatAim = s
    _G.BatAct = s
    if s then _startBatAim() else _stopBatAim() end
    _save()
end, 5)

