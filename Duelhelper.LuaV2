-- ====================== THEME ======================
local _theme = {
    Bg = Color3.fromRGB(35,28,55), Card = Color3.fromRGB(55,48,75),
    Acc = Color3.fromRGB(210,175,255), Txt = Color3.fromRGB(0,0,0),
    Dark = Color3.fromRGB(0,0,0), Out = Color3.fromRGB(190,155,255),
    Btn = Color3.fromRGB(85,75,115), Off = Color3.fromRGB(95,85,115),
    Glow = Color3.fromRGB(210,175,255), ProgBg = Color3.fromRGB(20,20,25),
    ProgFill = Color3.fromRGB(210,175,255),
}

-- ====================== KONFIGURATION ======================
local _cfgFile = "DuelHelper_Config.json"
local _en = {
    SpdB = false, SpdStl = false, InfJ = false, SpinB = false, Unwalk = false,
    AntiR = false, AutoStl = false, OptXR = false, ESP = false, AntiLag = false,
    BatAim = false, Galaxy = false, AntiTur = false, AntiBee = false, FOV110 = false,
}
local _val = {
    NSpd = 60, StlSpd = 29, SpinSp = 30, JmpP = 50, JmpC = 80,
    StlRad = 8, StlDur = 0.2, BatRad = 20, BatMove = 56.5,
}
_G.NormSpdAct = false _G.NormSpdV = 60 _G.StlSpdV = 29 _G.InfJAct = false
_G.SpinAct = false _G.SpinV = 30 _G.OptAct = false _G.XrayAct = false
_G.ESPAct = false _G.AntiRAct = false _G.BatAct = false _G.BatRadV = 20

-- Galaxy Mode Variablen
local _galSky, _galCC = nil, nil
local _defBright, _defClock, _defAmb, _defExp = _lig.Brightness, _lig.ClockTime, _lig.OutdoorAmbient, _lig.ExposureCompensation

-- Charakter
local _ch, _hum, _hrp = nil, nil, nil

-- Auto Steal
local _isStl = false, _stlStart = nil, _stlConn = nil, _animCache = {}, _promptCache = {}, _progConn = nil
local _progBar, _progFill, _progPct, _radInp, _progStat = nil, nil, nil, nil, nil

-- Bat Aimbot
local _batLook, _batAtt, _batAlign, _batEqTick = 0, _batUseTick = 0, _batRing = nil

-- Anti Turret
local _turTarget, _turConn = nil, nil
local _turDist = 60, _turPull = -5

-- Anti Bee
local _beeConn = nil
local _beeKeys = {"effect","vfx","fx","particle","camera","shake","blur","flash","visual","ui","item","bee","disco"}

-- ====================== CONFIG SAVE/LOAD ======================
local function _save()
    local d = {}
    for k,v in pairs(_en) do d[k] = v end
    for k,v in pairs(_val) do d[k] = v end
    if writefile then pcall(function() writefile(_cfgFile, _http:JSONEncode(d)) end) end
end
local function _load()
    pcall(function()
        if readfile and isfile and isfile(_cfgFile) then
            local d = _http:JSONDecode(readfile(_cfgFile))
            if d then
                for k,v in pairs(d) do
                    if _en[k] ~= nil then _en[k] = v elseif _val[k] ~= nil then _val[k] = v end
                end
                _G.NormSpdV = _val.NSpd _G.StlSpdV = _val.StlSpd _G.SpinV = _val.SpinSp _G.BatRadV = _val.BatRad
            end
        end
    end)
end
_load()

-- ====================== CHARAKTER SETUP ======================
local function _setupChar(c)
    _ch = c
    _hum = c:WaitForChild("Humanoid",5)
    _hrp = c:WaitForChild("HumanoidRootPart",5)
end
if _me.Character then _setupChar(_me.Character) end
_me.CharacterAdded:Connect(_setupChar)

-- ====================== SPEED BOOST ======================
local _spdConn = nil
local function _startSpd()
    if _spdConn then return end
    _spdConn = _run.Heartbeat:Connect(function()
        if not _en.SpdB or not _hrp or not _hum then return end
        local md = _hum.MoveDirection
        if md.Magnitude > 0 then
            _hrp.AssemblyLinearVelocity = Vector3.new(md.X * _G.NormSpdV, _hrp.AssemblyLinearVelocity.Y, md.Z * _G.NormSpdV)
        end
    end)
end
local function _stopSpd()
    if _spdConn then _spdConn:Disconnect() _spdConn = nil end
end

-- ====================== SPEED WHILE STEALING (LemonHub) ======================
local _spdStlConn = nil
local function _startSpdStl()
    if _spdStlConn then return end
    _spdStlConn = _run.Heartbeat:Connect(function()
        if not _en.SpdStl then return end
        local stlNow = _me:GetAttribute("Stealing") == true
        if not stlNow or not _hrp or not _hum then return end
        local md = _hum.MoveDirection
        if md.Magnitude > 0 then
            _hrp.AssemblyLinearVelocity = Vector3.new(md.X * _G.StlSpdV, _hrp.AssemblyLinearVelocity.Y, md.Z * _G.StlSpdV)
        end
    end)
end
local function _stopSpdStl()
    if _spdStlConn then _spdStlConn:Disconnect() _spdStlConn = nil end
end

-- ====================== INFINITE JUMP ======================
local function _infJmp()
    if not _en.InfJ or not _hrp then return end
    local v = _hrp.AssemblyLinearVelocity
    if v.Y < -_val.JmpC then _hrp.AssemblyLinearVelocity = Vector3.new(v.X, -_val.JmpC, v.Z) end
end
local function _onJmpReq()
    if not _en.InfJ or not _hrp then return end
    local v = _hrp.AssemblyLinearVelocity
    _hrp.AssemblyLinearVelocity = Vector3.new(v.X, _val.JmpP, v.Z)
end
_run.Heartbeat:Connect(_infJmp)
_inp.JumpRequest:Connect(_onJmpReq)

-- ====================== SPIN BOT ======================
local _spinBAV = nil
local function _killSpin()
    if _spinBAV then _spinBAV:Destroy() _spinBAV = nil end
    if _ch then
        local r = _ch:FindFirstChild("HumanoidRootPart")
        if r then
            for _,v in pairs(r:GetChildren()) do
                if v.Name == "DuelSpinBAV" then v:Destroy() end
            end
        end
    end
end
local function _startSpin()
    _killSpin()
    if not _ch then return end
    local r = _ch:FindFirstChild("HumanoidRootPart")
    if not r then return end
    _spinBAV = Instance.new("BodyAngularVelocity")
    _spinBAV.Name = "DuelSpinBAV"
    _spinBAV.MaxTorque = Vector3.new(0, math.huge, 0)
    _spinBAV.AngularVelocity = Vector3.new(0, _G.SpinV, 0)
    _spinBAV.Parent = r
end
_run.Heartbeat:Connect(function()
    if _en.SpinB and _spinBAV and _ch then
        _spinBAV.AngularVelocity = Vector3.new(0, _G.SpinV, 0)
    end
end)

-- ====================== UNWALK ======================
local _uwConn = nil
local function _startUw()
    if _uwConn then _uwConn:Disconnect() end
    _uwConn = _run.Heartbeat:Connect(function()
        if not _en.Unwalk then return end
        local c = _me.Character
        if not c then return end
        local h = c:FindFirstChildOfClass("Humanoid")
        if not h then return end
        local a = h:FindFirstChildOfClass("Animator")
        if a then
            for _,t in ipairs(a:GetPlayingAnimationTracks()) do t:Stop(0) end
        end
    end)
end

-- ====================== ANTI RAGDOLL ======================
local _ragConns = {}
local _lastVel = Vector3.new()
local function _ragClean()
    local c = _me.Character
    if not c then return end
    for _,v in pairs(c:GetDescendants()) do
        if v:IsA("BallSocketConstraint") or v:IsA("HingeConstraint") or v:IsA("NoCollisionConstraint") then
            pcall(function() v:Destroy() end)
        elseif v:IsA("Motor6D") then
            v.Enabled = true
        end
    end
    local h = c:FindFirstChildOfClass("Humanoid")
    if h then
        local a = h:FindFirstChildOfClass("Animator")
        if a then
            for _,t in pairs(a:GetPlayingAnimationTracks()) do
                local n = t.Animation and t.Animation.Name:lower() or ""
                if n:find("rag") or n:find("fall") or n:find("hurt") then t:Stop(0) end
            end
        end
    end
end
local function _startAR()
    if not _en.AntiR then return end
    local c = _me.Character or _me.CharacterAdded:Wait()
    local h = c:WaitForChild("Humanoid")
    table.insert(_ragConns, h.StateChanged:Connect(function()
        pcall(function() h:ChangeState(Enum.HumanoidStateType.Running) end)
        _ragClean()
    end))
    table.insert(_ragConns, _run.Heartbeat:Connect(function()
        if not _en.AntiR then return end
        local c2 = _me.Character
        if not c2 then return end
        local r2 = c2:FindFirstChild("HumanoidRootPart")
        if not r2 then return end
        local v = r2.AssemblyLinearVelocity
        if (v - _lastVel).Magnitude > 40 and v.Magnitude > 25 then
            r2.AssemblyLinearVelocity = v.Unit * 15
        end
        _lastVel = v
        _ragClean()
    end))
end
local function _stopAR()
    for _,c in pairs(_ragConns) do pcall(function() c:Disconnect() end) end
    _ragConns = {}
end
_me.CharacterAdded:Connect(function()
    if _en.AntiR then
        task.wait(0.5)
        _stopAR()
        _startAR()
    end
end)

-- ====================== BAT AIMBOT ======================
local function _getBat()
    local c = _me.Character
    if not c then return nil end
    for _,t in ipairs(c:GetChildren()) do
        if t:IsA("Tool") and t.Name:lower():find("bat") then return t end
    end
    local bp = _me:FindFirstChild("Backpack")
    if bp then
        for _,t in ipairs(bp:GetChildren()) do
            if t:IsA("Tool") and t.Name:lower():find("bat") then t.Parent = c return t end
        end
    end
    return nil
end
local function _nearestPlr()
    if not _hrp then return nil end
    local cl, d = nil, math.huge
    for _,p in ipairs(_plr:GetPlayers()) do
        if p ~= _me and p.Character then
            local r = p.Character:FindFirstChild("HumanoidRootPart")
            local h = p.Character:FindFirstChildOfClass("Humanoid")
            if r and h and h.Health > 0 then
                local dist = (r.Position - _hrp.Position).Magnitude
                if dist < d then d = dist cl = r end
            end
        end
    end
    return cl, d
end
local function _eqBat()
    local b = _me.Backpack:FindFirstChild("Bat") or (_ch and _ch:FindFirstChild("Bat"))
    if b and _hum then _hum:EquipTool(b) end
end
local function _startBatAim()
    if _batLook then _batLook:Disconnect() end
    if _hum then _hum.AutoRotate = false end
    _batAtt = Instance.new("Attachment", _hrp)
    _batAlign = Instance.new("AlignOrientation")
    _batAlign.Attachment0 = _batAtt
    _batAlign.Mode = Enum.OrientationAlignmentMode.OneAttachment
    _batAlign.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
    _batAlign.Responsiveness = 1000
    _batAlign.RigidityEnabled = true
    _batAlign.Parent = _hrp
    _batLook = _run.RenderStepped:Connect(function()
        if not _en.BatAim or not _hrp or not _batAlign then return end
        local t = _nearestPlr()
        if t then
            _batAlign.CFrame = CFrame.lookAt(_hrp.Position, Vector3.new(t.Position.X, _hrp.Position.Y, t.Position.Z))
        end
    end)
end
local function _stopBatAim()
    if _batLook then _batLook:Disconnect() _batLook = nil end
    if _batAlign then _batAlign:Destroy() _batAlign = nil end
    if _batAtt then _batAtt:Destroy() _batAtt = nil end
    if _hum then _hum.AutoRotate = true end
end
_run.Heartbeat:Connect(function()
    if not _en.BatAim or not _hrp or not _hum then return end
    local t, d = _nearestPlr()
    if t then
        local dir = (t.Position - _hrp.Position).Unit
        _hrp.AssemblyLinearVelocity = Vector3.new(dir.X * _val.BatMove, _hrp.AssemblyLinearVelocity.Y, dir.Z * _val.BatMove)
        if d <= _val.BatRad then
            if tick() - _batEqTick >= 0.3 then
                _eqBat()
                _batEqTick = tick()
            end
            if tick() - _batUseTick >= 0.3 then
                local b = _ch and _ch:FindFirstChild("Bat")
                if b then b:Activate() end
                _batUseTick = tick()
            end
        end
    end
end)
local function _showBatRing()
    if _batRing and _batRing.Parent then return end
    if not _hrp then return end
    local d = _val.BatRad * 2
    local r = Instance.new("Part")
    r.Name = "BatRing"
    r.Size = Vector3.new(d, 0.2, d)
    r.Anchored = true
    r.CanCollide = false
    r.Material = Enum.Material.Neon
    r.Color = _theme.Acc
    r.Transparency = 0.5
    r.CFrame = CFrame.new(_hrp.Position.X, _hrp.Position.Y - 2.5, _hrp.Position.Z)
    r.Parent = _ws
    Instance.new("CylinderMesh", r)
    _batRing = r
end
local function _hideBatRing()
    if _batRing then _batRing:Destroy() _batRing = nil end
end
_run.Heartbeat:Connect(function()
    if not _en.BatAim then _hideBatRing() return end
    if not _hrp then return end
    if not _batRing or not _batRing.Parent then _showBatRing() end
    if _batRing then
        _batRing.CFrame = CFrame.new(_hrp.Position.X, _hrp.Position.Y - 2.5, _hrp.Position.Z)
        _batRing.Size = Vector3.new(_val.BatRad * 2, 0.2, _val.BatRad * 2)
    end
end)

-- ====================== GALAXY MODE ======================
local function _updGal()
    if _en.Galaxy then
        if not _galSky then
            _galSky = Instance.new("Sky")
            _galSky.Name = "GalaxySky"
            _galSky.SkyboxBk = "rbxassetid://159454299"
            _galSky.SkyboxDn = "rbxassetid://159454296"
            _galSky.SkyboxFt = "rbxassetid://159454293"
            _galSky.SkyboxLf = "rbxassetid://159454286"
            _galSky.SkyboxRt = "rbxassetid://159454289"
            _galSky.SkyboxUp = "rbxassetid://159454291"
            _galSky.Parent = _lig
        end
        if not _galCC then
            _galCC = Instance.new("ColorCorrectionEffect")
            _galCC.Name = "GalaxyColorCorrection"
            _galCC.TintColor = Color3.fromRGB(180,100,255)
            _galCC.Saturation = 0.7
            _galCC.Brightness = 0.05
            _galCC.Contrast = 0.1
            _galCC.Parent = _lig
        end
        _lig.Brightness = 0
        _lig.ClockTime = 0
        _lig.ExposureCompensation = -2
        _lig.OutdoorAmbient = Color3.fromRGB(0,0,0)
        _lig.Ambient = Color3.fromRGB(30,20,50)
    else
        if _galSky then _galSky:Destroy() _galSky = nil end
        if _galCC then _galCC:Destroy() _galCC = nil end
        _lig.Brightness = _defBright
        _lig.ClockTime = _defClock
        _lig.ExposureCompensation = _defExp
        _lig.OutdoorAmbient = _defAmb
        _lig.Ambient = Color3.fromRGB(127,127,127)
    end
end

-- ====================== FOV 110 ======================
local function _updFOV()
    if _en.FOV110 then _cam.FieldOfView = 110 else _cam.FieldOfView = 70 end
end

-- ====================== OPTIMIZER + XRAY ======================
local _origTrans = {}
local _xray = false
local function _enableOptXray()
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        _lig.GlobalShadows = false
        _lig.Brightness = 2
        _lig.FogEnd = 9e9
        _lig.FogStart = 9e9
        for _,fx in ipairs(_lig:GetChildren()) do
            if fx:IsA("PostEffect") then fx.Enabled = false end
        end
    end)
    pcall(function()
        for _,obj in ipairs(_ws:GetDescendants()) do
            pcall(function()
                if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") or
                   obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles") then
                    obj.Enabled = false
                    obj:Destroy()
                elseif obj:IsA("SelectionBox") then
                    obj:Destroy()
                elseif obj:IsA("BasePart") then
                    obj.CastShadow = false
                    obj.Material = Enum.Material.Plastic
                elseif obj:IsA("Sky") then
                    obj:Destroy()
                end
            end)
        end
    end)
    _xray = true
    for _,obj in ipairs(_ws:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Anchored and
           (obj.Name:lower():find("base") or (obj.Parent and obj.Parent.Name:lower():find("base"))) then
            _origTrans[obj] = obj.LocalTransparencyModifier
            obj.LocalTransparencyModifier = 0.85
        end
    end
end
local function _disableOptXray()
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
        _lig.GlobalShadows = true
        _lig.FogEnd = 100000
        _lig.FogStart = 0
    end)
    if _xray then
        for p,v in pairs(_origTrans) do
            if p and p.Parent then p.LocalTransparencyModifier = v end
        end
        _origTrans = {}
        _xray = false
    end
end

-- ====================== ANTI LAG ======================
local _antiLagAct = false
local function _enableAntiLag()
    if _antiLagAct then return end
    _antiLagAct = true
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        settings().Rendering.AmbientOcclusion = false
        settings().Rendering.Shadows = false
        _lig.GlobalShadows = false
    end)
end
local function _disableAntiLag()
    if not _antiLagAct then return end
    _antiLagAct = false
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
        _lig.GlobalShadows = true
    end)
end

-- ====================== PLAYER ESP ======================
local _espBoxes = {}
local function _createESP(p)
    if p == _me or not p.Character then return end
    local c = p.Character
    local r = c:FindFirstChild("HumanoidRootPart")
    if not r then return end
    local b = Instance.new("BoxHandleAdornment")
    b.Name = "ESP_Box"
    b.Adornee = r
    b.Size = Vector3.new(4,5.5,2)
    b.Color3 = _theme.Acc
    b.Transparency = 0.5
    b.ZIndex = 10
    b.AlwaysOnTop = true
    b.Parent = c
    _espBoxes[p] = b
end
local function _enableESP()
    for _,p in ipairs(_plr:GetPlayers()) do
        if p ~= _me then _createESP(p) end
    end
    _plr.PlayerAdded:Connect(function(p)
        task.wait(0.5)
        if _en.ESP then _createESP(p) end
    end)
end
local function _disableESP()
    for _,b in pairs(_espBoxes) do pcall(function() b:Destroy() end) end
    _espBoxes = {}
end

-- ====================== AUTO STEAL (mit Progress Bar) ======================
local function _isMyBase(pn)
    local pl = _ws.Plots and _ws.Plots:FindFirstChild(pn)
    if not pl then return false end
    local s = pl:FindFirstChild("PlotSign")
    if s then
        local y = s:FindFirstChild("YourBase")
        if y and y:IsA("BillboardGui") then return y.Enabled == true end
    end
    return false
end
local function _scanPlot(pl)
    if not pl or not pl:IsA("Model") then return end
    if _isMyBase(pl.Name) then return end
    local pods = pl:FindFirstChild("AnimalPodiums")
    if not pods then return end
    for _,pod in ipairs(pods:GetChildren()) do
        if pod:IsA("Model") and pod:FindFirstChild("Base") then
            local spawn = pod.Base:FindFirstChild("Spawn")
            if spawn then
                table.insert(_animCache, { plot = pl.Name, slot = pod.Name, worldPosition = pod:GetPivot().Position, uid = pl.Name .. "_" .. pod.Name })
            end
        end
    end
end
local function _findPrompt(ad)
    if not ad then return nil end
    local cp = _promptCache[ad.uid]
    if cp and cp.Parent then return cp end
    local plots = _ws:FindFirstChild("Plots")
    if not plots then return nil end
    local plot = plots:FindFirstChild(ad.plot)
    if not plot then return nil end
    local pods = plot:FindFirstChild("AnimalPodiums")
    if not pods then return nil end
    local pod = pods:FindFirstChild(ad.slot)
    if not pod then return nil end
    local base = pod:FindFirstChild("Base")
    if not base then return nil end
    local sp = base:FindFirstChild("Spawn")
    if not sp then return nil end
    local att = sp:FindFirstChild("PromptAttachment")
    if not att then return nil end
    for _,p in ipairs(att:GetChildren()) do
        if p:IsA("ProximityPrompt") then _promptCache[ad.uid] = p return p end
    end
end
local function _nearestAnimal()
    if not _hrp then return nil end
    local b,bd = nil, math.huge
    for _,ad in ipairs(_animCache) do
        if not _isMyBase(ad.plot) and ad.worldPosition then
            local d = (_hrp.Position - ad.worldPosition).Magnitude
            if d < bd then bd = d b = ad end
        end
    end
    return b
end
local function _updProg(prog)
    if _progFill then _progFill.Size = UDim2.new(prog,0,1,0) end
    if _progPct then _progPct.Text = math.floor(prog*100) .. "%" end
end
local function _resetProg()
    if _progFill then _progFill.Size = UDim2.new(0,0,1,0) end
    if _progPct then _progPct.Text = "0%" end
    if _progStat then _progStat.Text = "READY" end
end
local function _startStlLoop()
    if _stlConn then _stlConn:Disconnect() end
    _stlConn = _run.Heartbeat:Connect(function()
        if not _en.AutoStl or _isStl then return end
        local t = _nearestAnimal()
        if not t then return end
        if not _hrp then return end
        if (_hrp.Position - t.worldPosition).Magnitude > _val.StlRad then return end
        local p = _promptCache[t.uid]
        if not p or not p.Parent then p = _findPrompt(t) end
        if p then
            _isStl = true
            _stlStart = tick()
            if _progStat then _progStat.Text = t.slot or "STEALING..." end
            if _progConn then _progConn:Disconnect() end
            _progConn = _run.Heartbeat:Connect(function()
                if not _isStl then _progConn:Disconnect() return end
                local prog = math.clamp((tick()-_stlStart)/_val.StlDur,0,1)
                _updProg(prog)
            end)
            task.spawn(function()
                pcall(function() p:InputHoldBegin() end)
                task.wait(_val.StlDur)
                pcall(function() p:InputHoldEnd() end)
                task.wait(0.1)
                _isStl = false
                _resetProg()
                if _progConn then _progConn:Disconnect() end
            end)
        end
    end)
end
task.spawn(function()
    task.wait(2)
    local plots = _ws:WaitForChild("Plots",10)
    if not plots then return end
    for _,pl in ipairs(plots:GetChildren()) do
        if pl:IsA("Model") then _scanPlot(pl) end
    end
    plots.ChildAdded:Connect(function(pl)
        if pl:IsA("Model") then task.wait(0.5) _scanPlot(pl) end
    end)
    task.spawn(function()
        while task.wait(5) do
            _animCache = {}
            for _,pl in ipairs(plots:GetChildren()) do
                if pl:IsA("Model") then _scanPlot(pl) end
            end
        end
    end)
end)
_startStlLoop()

-- ====================== ANTI TURRET ======================
local function _getWeapon()
    return _me.Backpack:FindFirstChild("Bat") or (_ch and _ch:FindFirstChild("Bat"))
end
local function _findTurret()
    if not _hrp then return nil end
    for _,obj in pairs(_ws:GetChildren()) do
        if obj.Name:find("Sentry") and not obj.Name:lower():find("bullet") then
            local ownerId = obj.Name:match("Sentry_(%d+)")
            if ownerId and tonumber(ownerId) == _me.UserId then else
                local part = obj:IsA("BasePart") and obj or (obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")))
                if part and (_hrp.Position - part.Position).Magnitude <= _turDist then return obj end
            end
        end
    end
    return nil
end
local function _startAntiTur()
    if _turConn then _turConn:Disconnect() end
    _turConn = _run.Heartbeat:Connect(function()
        if not _en.AntiTur then return end
        if _turTarget and _turTarget.Parent == _ws then
            if not _hrp then return end
            for _,p in pairs(_turTarget:GetDescendants()) do
                if p:IsA("BasePart") then p.CanCollide = false end
            end
            local main = _turTarget:IsA("Model") and (_turTarget.PrimaryPart or _turTarget:FindFirstChildWhichIsA("BasePart")) or _turTarget
            if main then main.CFrame = _hrp.CFrame * CFrame.new(0,0,_turPull) end
            local w = _getWeapon()
            if w then
                if w.Parent == _me.Backpack and _hum then _hum:EquipTool(w) end
                w:Activate()
                for _,r in pairs(w:GetDescendants()) do
                    if r:IsA("RemoteEvent") then pcall(function() r:FireServer() end) end
                end
            end
        else
            _turTarget = _findTurret()
        end
    end)
end
local function _stopAntiTur()
    if _turConn then _turConn:Disconnect() _turConn = nil end
    _turTarget = nil
end

-- ====================== ANTI BEE & DISCO ======================
local function _startAntiBee()
    if _beeConn then _beeConn:Disconnect() end
    _beeConn = _rep.DescendantAdded:Connect(function(r)
        if not _en.AntiBee then return end
        if r:IsA("RemoteEvent") then
            for _,kw in ipairs(_beeKeys) do
                if r.Name:lower():find(kw) then
                    pcall(function()
                        local cons = getconnections(r.OnClientEvent)
                        for _,c in pairs(cons) do
                            if c.Disable then c:Disable() end
                        end
                    end)
                    break
                end
            end
        end
    end)
end
local function _stopAntiBee()
    if _beeConn then _beeConn:Disconnect() _beeConn = nil end
end

-- ====================== AUTO PLAY LEFT/RIGHT ======================
local _aL, _aR = false, false
local _aLConn, _aRConn = nil, nil
local _aLPh, _aRPh = 1, 1
local _L1 = Vector3.new(-476.48,-6.28,92.73)
local _LEND = Vector3.new(-483.12,-4.95,94.80)
local _LFINAL = Vector3.new(-473.38,-8.40,22.34)
local _R1 = Vector3.new(-476.16,-6.52,25.62)
local _REND = Vector3.new(-483.04,-5.09,23.14)
local _RFINAL = Vector3.new(-476.17,-7.91,97.91)
local _FSPD = 59
local _RSPD = 30
local function _stopAutoL()
    if _aLConn then _aLConn:Disconnect() _aLConn = nil end
    _aLPh = 1
    _aL = false
    if _hum then _hum:Move(Vector3.zero, false) end
end
local function _stopAutoR()
    if _aRConn then _aRConn:Disconnect() _aRConn = nil end
    _aRPh = 1
    _aR = false
    if _hum then _hum:Move(Vector3.zero, false) end
end
local function _startAutoL()
    if _aLConn then _aLConn:Disconnect() end
    _aLPh = 1
    _aLConn = _run.Heartbeat:Connect(function()
        if not _aL or not _hrp or not _hum then return end
        if _aLPh == 1 then
            local d = _L1 - _hrp.Position
            if d.Magnitude < 1 then _aLPh = 2 return end
            local md = d.Unit
            _hum:Move(md, false)
            _hrp.AssemblyLinearVelocity = Vector3.new(md.X * _FSPD, _hrp.AssemblyLinearVelocity.Y, md.Z * _FSPD)
        elseif _aLPh == 2 then
            local d = _LEND - _hrp.Position
            if d.Magnitude < 1 then
                _aLPh = 0
                _hum:Move(Vector3.zero, false)
                _hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
                task.delay(0.1, function() if _aL then _aLPh = 3 end end)
                return
            end
            local md = d.Unit
            _hum:Move(md, false)
            _hrp.AssemblyLinearVelocity = Vector3.new(md.X * _FSPD, _hrp.AssemblyLinearVelocity.Y, md.Z * _FSPD)
        elseif _aLPh == 0 then
            return
        elseif _aLPh == 3 then
            local d = _L1 - _hrp.Position
            if d.Magnitude < 1 then _aLPh = 4 return end
            local md = d.Unit
            _hum:Move(md, false)
            _hrp.AssemblyLinearVelocity = Vector3.new(md.X * _RSPD, _hrp.AssemblyLinearVelocity.Y, md.Z * _RSPD)
        elseif _aLPh == 4 then
            local d = _LFINAL - _hrp.Position
            if d.Magnitude < 1 then
                _hum:Move(Vector3.zero, false)
                _hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
                _stopAutoL()
                return
            end
            local md = d.Unit
            _hum:Move(md, false)
            _hrp.AssemblyLinearVelocity = Vector3.new(md.X * _RSPD, _hrp.AssemblyLinearVelocity.Y, md.Z * _RSPD)
        end
    end)
end
local function _startAutoR()
    if _aRConn then _aRConn:Disconnect() end
    _aRPh = 1
    _aRConn = _run.Heartbeat:Connect(function()
        if not _aR or not _hrp or not _hum then return end
        if _aRPh == 1 then
            local d = _R1 - _hrp.Position
            if d.Magnitude < 1 then _aRPh = 2 return end
            local md = d.Unit
            _hum:Move(md, false)
            _hrp.AssemblyLinearVelocity = Vector3.new(md.X * _FSPD, _hrp.AssemblyLinearVelocity.Y, md.Z * _FSPD)
        elseif _aRPh == 2 then
            local d = _REND - _hrp.Position
            if d.Magnitude < 1 then
                _aRPh = 0
                _hum:Move(Vector3.zero, false)
                _hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
                task.delay(0.1, function() if _aR then _aRPh = 3 end end)
                return
            end
            local md = d.Unit
            _hum:Move(md, false)
            _hrp.AssemblyLinearVelocity = Vector3.new(md.X * _FSPD, _hrp.AssemblyLinearVelocity.Y, md.Z * _FSPD)
        elseif _aRPh == 0 then
            return
        elseif _aRPh == 3 then
            local d = _R1 - _hrp.Position
            if d.Magnitude < 1 then _aRPh = 4 return end
            local md = d.Unit
            _hum:Move(md, false)
            _hrp.AssemblyLinearVelocity = Vector3.new(md.X * _RSPD, _hrp.AssemblyLinearVelocity.Y, md.Z * _RSPD)
        elseif _aRPh == 4 then
            local d = _RFINAL - _hrp.Position
            if d.Magnitude < 1 then
                _hum:Move(Vector3.zero, false)
                _hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
                _stopAutoR()
                return
            end
            local md = d.Unit
            _hum:Move(md, false)
            _hrp.AssemblyLinearVelocity = Vector3.new(md.X * _RSPD, _hrp.AssemblyLinearVelocity.Y, md.Z * _RSPD)
        end
    end)
end

-- ====================== DROP BRAINROT ======================
local _dropAct = false
local function _drop()
    if _dropAct then return end
    local c = _me.Character
    if not c then return end
    local r = c:FindFirstChild("HumanoidRootPart")
    if not r then return end
    _dropAct = true
    if _hum then _hum.MaxHealth = math.huge _hum.Health = math.huge end
    local t0 = tick()
    local conn
    conn = _run.Heartbeat:Connect(function()
        local r2 = c and c:FindFirstChild("HumanoidRootPart")
        if not r2 then conn:Disconnect() _dropAct = false return end
        if tick() - t0 >= 0.2 then
            conn:Disconnect()
            local rp = RaycastParams.new()
            rp.FilterDescendantsInstances = {c}
            rp.FilterType = Enum.RaycastFilterType.Exclude
            local rr = _ws:Raycast(r2.Position, Vector3.new(0,-2000,0), rp)
            if rr then
                local off = (_hum and _hum.HipHeight or 2) + (r2.Size.Y/2)
                r2.CFrame = CFrame.new(r2.Position.X, rr.Position.Y+off, r2.Position.Z)
                r2.AssemblyLinearVelocity = Vector3.new(0,0,0)
            end
            _dropAct = false
            return
        end
        r2.AssemblyLinearVelocity = Vector3.new(r2.AssemblyLinearVelocity.X, 150, r2.AssemblyLinearVelocity.Z)
    end)
end

-- ====================== TP DOWN ======================
local function _tpDown()
    if not _ch or not _hrp or not _hum then return end
    local rp = RaycastParams.new()
    rp.FilterDescendantsInstances = {_ch}
    rp.FilterType = Enum.RaycastFilterType.Exclude
    local res = _ws:Raycast(_hrp.Position, Vector3.new(0,-1000,0), rp)
    if res then
        local ty = res.Position.Y + (_hum.HipHeight or 2) + _hrp.Size.Y/2 + 0.3
        _hrp.CFrame = CFrame.new(_hrp.Position.X, ty, _hrp.Position.Z) * _hrp.CFrame.Rotation
    else
        _hrp.CFrame = _hrp.CFrame * CFrame.new(0,-30,0)
    end
end

-- ====================== FPS / PING ANZEIGE ======================
local _fpsC = 0
local _lastT = tick()
local _fps = 60
local _ping = 0
_run.RenderStepped:Connect(function()
    _fpsC = _fpsC + 1
    if tick() - _lastT >= 1 then
        _fps = _fpsC
        _fpsC = 0
        _lastT = tick()
        _ping = math.floor(_me:GetNetworkPing() * 1000)
    end
end)

