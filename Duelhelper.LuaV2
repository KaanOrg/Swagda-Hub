-- UI Helfer (NumberInput, Toggle)
local function _numInp(p, lbl, def, minv, maxv, cb, ord)
    local f = Instance.new("Frame", p)
    f.Size = UDim2.new(1,0,0,32)
    f.BackgroundColor3 = _theme.Card
    f.BorderSizePixel = 0
    f.LayoutOrder = ord
    Instance.new("UICorner", f).CornerRadius = UDim.new(0,5)
    local lab = Instance.new("TextLabel", f)
    lab.Size = UDim2.new(0.6,0,1,0)
    lab.Position = UDim2.new(0,6,0,0)
    lab.BackgroundTransparency = 1
    lab.Text = lbl
    lab.TextColor3 = Color3.fromRGB(0,0,0)
    lab.Font = Enum.Font.GothamBold
    lab.TextSize = 10
    lab.TextXAlignment = Enum.TextXAlignment.Left
    local box = Instance.new("TextBox", f)
    box.Size = UDim2.new(0,45,0,20)
    box.Position = UDim2.new(1,-52,0.5,-10)
    box.BackgroundColor3 = _theme.Btn
    box.Text = tostring(def)
    box.TextColor3 = Color3.fromRGB(0,0,0)
    box.Font = Enum.Font.GothamBold
    box.TextSize = 11
    Instance.new("UICorner", box).CornerRadius = UDim.new(0,4)
    local cur = def
    box.FocusLost:Connect(function()
        local n = tonumber(box.Text)
        if n then
            cur = math.clamp(n, minv, maxv)
            box.Text = tostring(cur)
            cb(cur)
        else
            box.Text = tostring(cur)
        end
    end)
end

local function _tog(p, lbl, def, cb, ord)
    local f = Instance.new("Frame", p)
    f.Size = UDim2.new(1,0,0,28)
    f.BackgroundColor3 = _theme.Card
    f.BorderSizePixel = 0
    f.LayoutOrder = ord
    Instance.new("UICorner", f).CornerRadius = UDim.new(0,5)
    local lab = Instance.new("TextLabel", f)
    lab.Size = UDim2.new(0.7,0,1,0)
    lab.Position = UDim2.new(0,6,0,0)
    lab.BackgroundTransparency = 1
    lab.Text = lbl
    lab.TextColor3 = Color3.fromRGB(0,0,0)
    lab.Font = Enum.Font.GothamBold
    lab.TextSize = 10
    lab.TextXAlignment = Enum.TextXAlignment.Left
    local tr = Instance.new("Frame", f)
    tr.Size = UDim2.new(0,38,0,16)
    tr.Position = UDim2.new(1,-45,0.5,-8)
    tr.BackgroundColor3 = def and _theme.Acc or _theme.Off
    tr.BorderSizePixel = 0
    Instance.new("UICorner", tr).CornerRadius = UDim.new(1,0)
    local dot = Instance.new("Frame", tr)
    dot.Size = UDim2.new(0,12,0,12)
    dot.Position = def and UDim2.new(1,-15,0.5,-6) or UDim2.new(0,3,0.5,-6)
    dot.BackgroundColor3 = Color3.fromRGB(255,255,255)
    dot.BorderSizePixel = 0
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1,0)
    local st = def
    local btn = Instance.new("TextButton", f)
    btn.Size = UDim2.new(1,0,1,0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.MouseButton1Click:Connect(function()
        st = not st
        tr.BackgroundColor3 = st and _theme.Acc or _theme.Off
        dot.Position = st and UDim2.new(1,-15,0.5,-6) or UDim2.new(0,3,0.5,-6)
        cb(st)
    end)
end

-- MAIN CONTENT
local ord = 1
_numInp(_mainC, "Speed", _val.NSpd, 10, 500, function(v) _val.NSpd = v _G.NormSpdV = v _save() end, ord); ord = ord+1
_numInp(_mainC, "Steal Speed", _val.StlSpd, 10, 150, function(v) _val.StlSpd = v _G.StlSpdV = v _save() end, ord); ord = ord+1
_tog(_mainC, "Speed Boost", _en.SpdB, function(v) _en.SpdB = v _G.NormSpdAct = v if v then _startSpd() else _stopSpd() end _save() end, ord); ord = ord+1
_tog(_mainC, "Speed While Stealing", _en.SpdStl, function(v) _en.SpdStl = v if v then _startSpdStl() else _stopSpdStl() end _save() end, ord); ord = ord+1
_numInp(_mainC, "Auto Steal Radius", _val.StlRad, 5, 15, function(v) _val.StlRad = v if _radInp then _radInp.Text = tostring(v) end _save() end, ord); ord = ord+1
_tog(_mainC, "Infinite Jump", _en.InfJ, function(v) _en.InfJ = v _G.InfJAct = v _save() end, ord); ord = ord+1
_tog(_mainC, "Spin Bot", _en.SpinB, function(v) _en.SpinB = v _G.SpinAct = v if v then _startSpin() else _killSpin() end _save() end, ord); ord = ord+1
_numInp(_mainC, "Spin Speed", _val.SpinSp, 5, 80, function(v) _val.SpinSp = v _G.SpinV = v if _spinBAV then _spinBAV.AngularVelocity = Vector3.new(0,v,0) end _save() end, ord); ord = ord+1
_tog(_mainC, "Bat Aimbot", _en.BatAim, function(v) _en.BatAim = v _G.BatAct = v if v then _startBatAim() else _stopBatAim() end _save() end, ord); ord = ord+1
_numInp(_mainC, "Bat Radius", _val.BatRad, 5, 50, function(v) _val.BatRad = v _G.BatRadV = v _save() end, ord); ord = ord+1
_tog(_mainC, "Unwalk", _en.Unwalk, function(v) _en.Unwalk = v if v then _startUw() end _save() end, ord); ord = ord+1
_tog(_mainC, "Anti Ragdoll", _en.AntiR, function(v) _en.AntiR = v _G.AntiRAct = v if v then _stopAR() _startAR() else _stopAR() end _save() end, ord); ord = ord+1
_tog(_mainC, "Auto Steal", _en.AutoStl, function(v) _en.AutoStl = v _save() end, ord); ord = ord+1
_tog(_mainC, "Anti Lag", _en.AntiLag, function(v) _en.AntiLag = v if v then _enableAntiLag() else _disableAntiLag() end _save() end, ord); ord = ord+1
local _saveF = Instance.new("Frame", _mainC)
_saveF.Size = UDim2.new(1,0,0,28)
