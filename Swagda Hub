-- ====================== DROP BRAINROT ======================
local dropActive = false
local DROP_ASCEND_DURATION = 0.2
local DROP_ASCEND_SPEED = 150
local function runDropBrainrot()
    if dropActive then return end
    local character = LocalPlayer.Character
    if not character then return end
    local root = character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    dropActive = true
    if hum then hum.MaxHealth = math.huge; hum.Health = math.huge end
    local t0 = tick()
    local dc
    dc = RunService.Heartbeat:Connect(function()
        local r = character and character:FindFirstChild("HumanoidRootPart")
        if not r then
            dc:Disconnect()
            dropActive = false
            return
        end
        if tick() - t0 >= DROP_ASCEND_DURATION then
            dc:Disconnect()
            local rp = RaycastParams.new()
            rp.FilterDescendantsInstances = {character}
            rp.FilterType = Enum.RaycastFilterType.Exclude
            local rr = workspace:Raycast(r.Position, Vector3.new(0, -2000, 0), rp)
            if rr then
                local hum2 = character:FindFirstChildOfClass("Humanoid")
                local off = (hum2 and hum2.HipHeight or 2) + (r.Size.Y / 2)
                r.CFrame = CFrame.new(r.Position.X, rr.Position.Y + off, r.Position.Z)
                r.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            end
            dropActive = false
            return
        end
        r.AssemblyLinearVelocity = Vector3.new(r.AssemblyLinearVelocity.X, DROP_ASCEND_SPEED, r.AssemblyLinearVelocity.Z)
    end)
end

-- ====================== TP DOWN ======================
local function performTpDown()
    if not char or not hrp or not hum then return end
    local rp = RaycastParams.new()
    rp.FilterDescendantsInstances = {char}
    rp.FilterType = Enum.RaycastFilterType.Exclude
    rp.IgnoreWater = true
    local result = workspace:Raycast(hrp.Position, Vector3.new(0, -1000, 0), rp)
    if result then
        local targetY = result.Position.Y + (hum.HipHeight or 2) + hrp.Size.Y / 2 + 0.3
        hrp.CFrame = CFrame.new(hrp.Position.X, targetY, hrp.Position.Z) * hrp.CFrame.Rotation
    else
        hrp.CFrame = hrp.CFrame * CFrame.new(0, -30, 0)
    end
end

