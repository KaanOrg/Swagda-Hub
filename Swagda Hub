local function createNumberInput(parent, labelText, defaultValue, minVal, maxVal, callback, order)
    local frame = Instance.new("Frame", parent)
    frame.Size = UDim2.new(1, 0, 0, 32)
    frame.BackgroundColor3 = THEME.Card
    frame.BorderSizePixel = 0
    frame.LayoutOrder = order
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 5)
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(0.6, 0, 1, 0)
    label.Position = UDim2.new(0, 6, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = labelText
    label.TextColor3 = Color3.fromRGB(0, 0, 0)
    label.Font = Enum.Font.GothamBold
    label.TextSize = 10
    label.TextXAlignment = Enum.TextXAlignment.Left
    local textBox = Instance.new("TextBox", frame)
    textBox.Size = UDim2.new(0, 45, 0, 20)
    textBox.Position = UDim2.new(1, -52, 0.5, -10)
    textBox.BackgroundColor3 = THEME.ButtonBg
    textBox.Text = tostring(defaultValue)
    textBox.TextColor3 = Color3.fromRGB(0, 0, 0)
    textBox.Font = Enum.Font.GothamBold
    textBox.TextSize = 11
    Instance.new("UICorner", textBox).CornerRadius = UDim.new(0, 4)
    local currentVal = defaultValue
    textBox.FocusLost:Connect(function()
        local num = tonumber(textBox.Text)
        if num then
            currentVal = math.clamp(num, minVal, maxVal)
            textBox.Text = tostring(currentVal)
            callback(currentVal)
        else
            textBox.Text = tostring(currentVal)
        end
    end)
end
local function createToggle(parent, labelText, defaultValue, callback, order)
    local frame = Instance.new("Frame", parent)
    frame.Size = UDim2.new(1, 0, 0, 28)
    frame.BackgroundColor3 = THEME.Card
    frame.BorderSizePixel = 0
    frame.LayoutOrder = order
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 5)
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(0.7, 0, 1, 0)
    label.Position = UDim2.new(0, 6, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = labelText
    label.TextColor3 = Color3.fromRGB(0, 0, 0)
    label.Font = Enum.Font.GothamBold
    label.TextSize = 10
    label.TextXAlignment = Enum.TextXAlignment.Left
    local track = Instance.new("Frame", frame)
    track.Size = UDim2.new(0, 38, 0, 16)
    track.Position = UDim2.new(1, -45, 0.5, -8)
    track.BackgroundColor3 = defaultValue and THEME.Accent or THEME.ToggleOff
    track.BorderSizePixel = 0
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
    local dot = Instance.new("Frame", track)
    dot.Size = UDim2.new(0, 12, 0, 12)
    dot.Position = defaultValue and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 3, 0.5, -6)
    dot.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    dot.BorderSizePixel = 0
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
    local state = defaultValue
    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.MouseButton1Click:Connect(function()
        state = not state
        track.BackgroundColor3 = state and THEME.Accent or THEME.ToggleOff
        dot.Position = state and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 3, 0.5, -6)
        callback(state)
    end)
end

