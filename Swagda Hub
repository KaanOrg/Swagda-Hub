-- ====================== ANTI RAGDOLL ======================
local ragConns = {}
local lastVel = Vector3.new()
local function ragClean()
    local c = LocalPlayer.Character
    if not c then return end
    for _, v in pairs(c:GetDescendants()) do
        if v:IsA("BallSocketConstraint") or v:IsA("HingeConstraint") or v:IsA("NoCollisionConstraint") then
            pcall(function() v:Destroy() end)
        elseif v:IsA("Motor6D") then
            v.Enabled = true
        end
    end
    local humanoid = c:FindFirstChildOfClass("Humanoid")
    if humanoid then
        local anim = humanoid:FindFirstChildOfClass("Animator")
        if anim then
            for _, t in pairs(anim:GetPlayingAnimationTracks()) do
                local n = t.Animation and t.Animation.Name:lower() or ""
                if n:find("rag") or n:find("fall") or n:find("hurt") then t:Stop(0) end
            end
        end
    end
end
local function enableAntiRagdoll()
    if not Enabled.AntiRagdoll then return end
    local c = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local humanoid = c:WaitForChild("Humanoid")
    table.insert(ragConns, humanoid.StateChanged:Connect(function()
        pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.Running) end)
        ragClean()
    end))
    table.insert(ragConns, RunService.Heartbeat:Connect(function()
        if not Enabled.AntiRagdoll then return end
        local c2 = LocalPlayer.Character
        if not c2 then return end
        local hrp2 = c2:FindFirstChild("HumanoidRootPart")
        if not hrp2 then return end
        local vel = hrp2.AssemblyLinearVelocity
        if (vel - lastVel).Magnitude > 40 and vel.Magnitude > 25 then
            hrp2.AssemblyLinearVelocity = vel.Unit * 15
        end
        lastVel = vel
        ragClean()
    end))
end
local function disableAntiRagdoll()
    for _, conn in pairs(ragConns) do pcall(function() conn:Disconnect() end) end
    ragConns = {}
end
LocalPlayer.CharacterAdded:Connect(function()
    if Enabled.AntiRagdoll then
        task.wait(0.5)
        disableAntiRagdoll()
        enableAntiRagdoll()
    end
end)

-- ====================== BAT AIMBOT ======================
local function getBat()
    local c = LocalPlayer.Character
    if not c then return nil end
    for _, t in ipairs(c:GetChildren()) do
        if t:IsA("Tool") and t.Name:lower():find("bat") then return t end
    end
    local bp = LocalPlayer:FindFirstChild("Backpack")
    if bp then
        for _, t in ipairs(bp:GetChildren()) do
            if t:IsA("Tool") and t.Name:lower():find("bat") then t.Parent = c; return t end
        end
    end
    return nil
end
local function getNearestPlayer()
    if not hrp then return nil, math.huge end
    local closest, minDist = nil, math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local tHRP = plr.Character:FindFirstChild("HumanoidRootPart")
            local tHum = plr.Character:FindFirstChildOfClass("Humanoid")
            if tHRP and tHum and tHum.Health > 0 then
                local d = (tHRP.Position - hrp.Position).Magnitude
                if d < minDist then minDist = d; closest = tHRP end
            end
        end
    end
    return closest, minDist
end
local function equipBat()
    local bat = LocalPlayer.Backpack:FindFirstChild("Bat") or (char and char:FindFirstChild("Bat"))
    if bat and hum then hum:EquipTool(bat) end
end
local function startBatAimbot()
    if batLookConn then batLookConn:Disconnect() end
    if hum then hum.AutoRotate = false end
    batAttachment = Instance.new("Attachment")
    batAttachment.Parent = hrp
    batAlign = Instance.new("AlignOrientation")
    batAlign.Attachment0 = batAttachment
    batAlign.Mode = Enum.OrientationAlignmentMode.OneAttachment
    batAlign.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
    batAlign.Responsiveness = 1000
    batAlign.RigidityEnabled = true
    batAlign.Parent = hrp
    batLookConn = RunService.RenderStepped:Connect(function()
        if not Enabled.BatAimbot or not hrp or not batAlign then return end
        local target = getNearestPlayer()
        if target then
            batAlign.CFrame = CFrame.lookAt(hrp.Position, Vector3.new(target.Position.X, hrp.Position.Y, target.Position.Z))
        end
    end)
end
local function stopBatAimbot()
    if batLookConn then batLookConn:Disconnect(); batLookConn = nil end
    if batAlign then batAlign:Destroy(); batAlign = nil end
    if batAttachment then batAttachment:Destroy(); batAttachment = nil end
    if hum then hum.AutoRotate = true end
end
RunService.Heartbeat:Connect(function()
    if not Enabled.BatAimbot or not hrp or not hum then return end
    local target, dist = getNearestPlayer()
    if target then
        local dir = (target.Position - hrp.Position).Unit
        hrp.AssemblyLinearVelocity = Vector3.new(dir.X * Values.BatMoveSpeed, hrp.AssemblyLinearVelocity.Y, dir.Z * Values.BatMoveSpeed)
        if dist <= Values.BatRadius then
            if tick() - batEquipTick >= 0.3 then
