-- ====================== INFINITE JUMP ======================
local function handleInfinityJump()
    if not Enabled.InfiniteJump or not hrp then return end
    local vel = hrp.AssemblyLinearVelocity
    if vel.Y < -Values.JumpClamp then
        hrp.AssemblyLinearVelocity = Vector3.new(vel.X, -Values.JumpClamp, vel.Z)
    end
end
local function onJumpRequest()
    if not Enabled.InfiniteJump or not hrp then return end
    local vel = hrp.AssemblyLinearVelocity
    hrp.AssemblyLinearVelocity = Vector3.new(vel.X, Values.JumpPower, vel.Z)
end
